# Spotify Web API credentials (required) — register an app at
# https://developer.spotify.com/dashboard and add yourself under User Management.
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Last.fm API key (optional but strongly recommended) — sidesteps Spotify's
# brutal Dev Mode daily quota for the discovery phase. Get one at
# https://www.last.fm/api/account/create (instant, free, no approval).
# When present, the script does artist+track discovery via Last.fm +
# ListenBrainz first, falling back to Spotify only if those don't have a mapping.
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_SHARED_SECRET=optional_only_needed_if_writing_to_lastfm

# Setlist.fm API key (optional) — only needed for "concert mode": build a
# playlist from an artist's recent live setlists instead of top tracks.
# Get one at https://www.setlist.fm/settings/api (instant, free, no approval).
# Default rate limit is 2 req/sec, 1440/day — plenty for occasional use.
SETLISTFM_API_KEY=your_setlistfm_api_key_here
